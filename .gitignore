# Root GitIgnore
# This file handles root-level ignores. Subfolders like frontend/ and backend/
# still use their own .gitignore files.

# Dependencies
node_modules/
jspm_packages/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE/Editors
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# Sensitive files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/config/*.json

# Build outputs
dist/
build/
out/
.next/
